# The URL the browser uses to reach each backend:
NEXT_PUBLIC_PYTHON_API=http://localhost:8000
NEXT_PUBLIC_NODE_API=http://localhost:3001

# The origin the frontend is served from (used for backend CORS allow-list):
FRONTEND_ORIGIN=http://localhost:3000

# --- GitHub Codespaces example (replace <codespace> with your codespace name) ---
# NEXT_PUBLIC_PYTHON_API=https://<codespace>-8000.app.github.dev
# NEXT_PUBLIC_NODE_API=https://<codespace>-3001.app.github.dev
# FRONTEND_ORIGIN=https://<codespace>-3000.app.github.dev
